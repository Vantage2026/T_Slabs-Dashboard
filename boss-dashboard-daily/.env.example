# --- Google ---
# Local: service account JSON key via env (no key file needed if you paste PEM):
# Share both spreadsheets with this email (Viewer is enough).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# GitHub Actions: use Workload Identity Federation (no private key in repo).
# Repo secrets: GOOGLE_WORKLOAD_IDENTITY_PROVIDER + GOOGLE_SERVICE_ACCOUNT_EMAIL
# See README and https://cloud.google.com/iam/docs/workload-identity-federation-with-deployment-pipelines

# Or OAuth desktop client + token file from another project:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_TOKEN_FILE=.state/google-oauth-token.json

# --- FedEx ---
# Option A — No developer API: sheet tracking #s + public FedEx links on the HTML dashboard.
SKIP_FEDEX_API=1
#
# Option B — FedEx Track API (live status text on the HTML dashboard)
# Leave SKIP_FEDEX_API unset or 0, then set:
# FEDEX_API_KEY=
# FEDEX_SECRET_KEY=
# FEDEX_USE_SANDBOX=1

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 numbers, e.g. +15551234567
TWILIO_FROM_E164=
# One E.164 number, or several separated by commas (each gets a copy of the SMS)
BOSS_PHONE_E164=

# Required for SMS: public URL of report.html (CI sets a default for GitHub Pages)
DASHBOARD_PUBLIC_URL=
# Short line before the URL in the text (keep brief — one SMS segment)
SMS_INTRO=Card shipments — open your dashboard:

# Spreadsheets (defaults match your links)
SHEET_KAI_ID=15oaXW2GEyMl7ES5AV_nJIdx7wG0nmMgoRjiEzyaax1A
SHEET_KAI_GID=1560013633
SHEET_MOMO_ID=1BTlXaIMMDE9qcZRAfGOnM4ZNvUHjA1X06wTOTvRFnvo
SHEET_MOMO_GID=47718698
SHEET_KAI_LABEL=Kai 2026
SHEET_MOMO_LABEL=Momo/Tyler 2026

# If a sheet uses different columns, set 0-based indices:
# COL_DATE_INDEX=0
# COL_CARDS_INDEX=1
# COL_TRACKING_INDEX=2
# COL_DELIVERED_INDEX=5
