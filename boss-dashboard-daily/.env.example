# --- Google (pick one) ---
# Service account: share both spreadsheets with this email (Viewer is enough).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Or OAuth desktop client + token file from another project:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_TOKEN_FILE=.state/google-oauth-token.json

# --- FedEx Developer Portal (production keys; use sandbox below for tests) ---
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
# FEDEX_USE_SANDBOX=1

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 numbers, e.g. +15551234567
TWILIO_FROM_E164=
BOSS_PHONE_E164=

# Optional: append link to hosted HTML (upload dist/report.html yourself or use CI)
DASHBOARD_PUBLIC_URL=
SMS_INTRO=Daily card shipment tracking:

